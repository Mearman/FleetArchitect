# Fast pre-push gate: whole-project typecheck + lint. The full test suite runs
# in CI — it is slow and the heavy SI guards flake under vitest's
# file-parallelism, which made a `pnpm test` gate here unreliable. pre-commit
# already lints staged files; this adds a whole-project typecheck so cross-file
# type errors are caught before push.
pnpm typecheck && pnpm lint
